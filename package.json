{
  "name": "grimoire-wizard",
  "version": "0.5.2",
  "description": "Config-driven CLI wizard framework. Define interactive terminal wizards in YAML/JSON with back-navigation, conditional branching, theming, and structured output.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "grimoire": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "schema:generate": "echo \"Schema is hand-maintained\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "wizard",
    "tui",
    "terminal",
    "prompt",
    "interactive",
    "yaml",
    "json",
    "config-driven",
    "back-navigation",
    "conditional",
    "theming",
    "inquirer",
    "clack"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YosefHayim/grimoire.git"
  },
  "author": "Yosef Hayim (https://github.com/YosefHayim)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "cosmiconfig": "^9.0.0",
    "figlet": "^1.10.0",
    "gradient-string": "^3.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
